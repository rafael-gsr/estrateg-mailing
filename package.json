{
  "name": "estrateg-mailing",
  "author": "rafaelgomes1404@gmail.com",
  "description": "Manage the comunication with your customers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/electron.config.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:vite dev:electron & tsc --watch --project ./electron/tsconfig.json",
    "dev:vite": "vite",
    "dev:electron": "yarn transpile:electron && cross-env NODE_ENV=development electron .",
    "build:vite": "tsc -b && vite build",
    "clear": "rm -rdf ./dist/ ./dist-electron/ ./dist-react/",
    "lint": "eslint .",
    "preview": "vite preview",
    "transpile:electron": "tsc --project ./electron/tsconfig.json",
    "dist:mac": "NODE_ENV=production yarn transpile:electron && yarn build:vite && electron-builder --mac --arm64",
    "dist:linux": "NODE_ENV=production yarn transpile:electron && yarn build:vite && electron-builder --linux --x64",
    "dist:win": "NODE_ENV=production yarn transpile:electron && yarn build:vite && electron-builder --win --x64"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.1.1",
    "@material-ui/core": "^5.0.0-beta.5",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/x-date-pickers": "^8.9.2",
    "dayjs": "^1.11.13",
    "electron-store": "^10.0.1",
    "nodemailer": "^6.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.60.0",
    "react-router": "^7.6.0",
    "sass": "^1.89.0",
    "sequelize": "^6.37.6",
    "sqlite3": "^5.1.7",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/electron": "^1.6.12",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sequelize": "^4.28.20",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.3",
    "electron-builder": "^25.1.8",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitest": "^3.0.9",
    "yarn-run-all": "^3.1.1",
    "zod": "^3.24.2"
  }
}
